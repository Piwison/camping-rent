# Booking enquiries are stored in Postgres via the Supabase config below
# (ADR-0007). Without Supabase configured, enquiries are logged server-side so
# the booking flow still works in local development. (Enquiries previously went
# to Notion — ADR-0003, now superseded.)

# Canonical site origin (no trailing slash). Used for absolute URLs in
# metadata, sitemap.xml, and robots.txt. Defaults to http://localhost:3000.
# Set this to your production domain at build time, e.g. https://basecamp.tw
NEXT_PUBLIC_SITE_URL=

# Supabase — Phase 2 datastore for the Catalog and Enquiries (ADR-0006/0007).
# Find these in your Supabase project: Settings → API.
#   1. Run the schema: supabase/migrations/20260529120000_init.sql (the GitHub
#      integration applies it on merge; or paste it in the SQL editor).
#   2. Set the values below in .env.local (the service-role key is secret —
#      server-only, never expose it to the client or commit it).
#   3. Seed from the current Catalog: npm run seed
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vendor auth (Supabase Auth, email + password — ADR-0006). The browser and
# server auth clients use the anon (publishable) key; safe to expose.
#   1. Same project as above; URL is identical to SUPABASE_URL.
#   2. Create the single Vendor account: Supabase dashboard → Authentication →
#      Users → Add user (email + password). No public sign-up.
# When these are unset, /admin stays open (no lock-out in un-wired local dev).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
