# Booking enquiries are written to a Notion database.
# Without these set, enquiries are logged server-side (the booking flow still
# works for local development).
#
# Setup:
#   1. Create an internal integration at https://www.notion.so/my-integrations
#      and copy its "Internal Integration Secret".
#   2. Open the "Basecamp & Co. — Enquiries" database in Notion → ••• menu →
#      Connections → add your integration so it can write rows.
#   3. Copy the values below into a .env.local file (never commit real secrets).

NOTION_TOKEN=
NOTION_ENQUIRIES_DB_ID=262dc24a58ae4fee83115f579f0405e4

# Canonical site origin (no trailing slash). Used for absolute URLs in
# metadata, sitemap.xml, and robots.txt. Defaults to http://localhost:3000.
# Set this to your production domain at build time, e.g. https://basecamp.tw
NEXT_PUBLIC_SITE_URL=
